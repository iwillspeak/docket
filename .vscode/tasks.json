{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "cargo build",
			"problemMatcher": ["$rustc"],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "test",
			"type": "shell",
			"command": "cargo test",
			"problemMatcher": ["$rustc"],
			"group": {
				"kind": "test",
				"isDefault": true
			}
		},
		{
			"label": "fmt",
			"type": "shell",
			"command": "cargo fmt",
			"problemMatcher": []
		},
		{
			"label": "regenerate-site",
			"type": "shell",
			"command": "cargo run -- -s docs/ -t output/",
			"problemMatcher": ["$rustc"],
			"group": "build"
		}
	]
}